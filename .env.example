# Copy to .env and edit as needed: cp .env.example .env

# Postgres (Event Store)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=apppass
POSTGRES_PORT=5432

# Convenience variables for compose
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppass
POSTGRES_DB=appdb
DATABASE_URL=postgres://appuser:apppass@localhost:5432/appdb?sslmode=disable
DB_MAX_RETRIES=30
DB_RETRY_DELAY=1

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=user-events
KAFKA_RETRY_DELAY=2
KAFKA_PORT=9092
ZOOKEEPER_PORT=2181

# API
API_PORT=8081
PROJECTION_ENABLED=true
